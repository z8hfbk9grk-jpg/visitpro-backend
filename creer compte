<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Créer compte VisitPro</title>
<style>
  body { font-family: sans-serif; background: #0f0f0f; color: #f0ede8; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
  .box { background: #181818; border: 1px solid #2a2a2a; border-radius: 12px; padding: 40px; width: 400px; text-align: center; }
  h2 { color: #D4A853; margin-bottom: 8px; }
  p { color: #6b6660; font-size: 0.85rem; margin-bottom: 24px; }
  button { background: #D4A853; color: #0f0f0f; border: none; padding: 14px 32px; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; width: 100%; }
  button:disabled { opacity: 0.5; }
  .result { margin-top: 20px; padding: 14px; border-radius: 8px; font-size: 0.85rem; display: none; }
  .result.ok { background: rgba(76,175,125,0.15); border: 1px solid rgba(76,175,125,0.3); color: #4CAF7D; }
  .result.err { background: rgba(224,90,90,0.15); border: 1px solid rgba(224,90,90,0.3); color: #E05A5A; }
</style>
</head>
<body>
<div class="box">
  <h2>VisitPro</h2>
  <p>Cliquez sur le bouton pour créer votre compte admin.<br>Cette page ne s'utilise qu'une seule fois.</p>
  <button id="btn" onclick="creerCompte()">Créer mon compte</button>
  <div class="result" id="result"></div>
</div>
<script>
async function creerCompte() {
  const btn = document.getElementById('btn');
  const result = document.getElementById('result');
  btn.disabled = true;
  btn.textContent = 'Création en cours...';
  result.style.display = 'none';

  try {
    const res = await fetch('https://9699b504-9af4-47d3-b897-b6259f7336a2-00-1v704rlp4aqu4.kirk.replit.dev/api/agents', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nom: 'Valldeneu',
        prenom: 'Bryan',
        email: 'bryanvalldeneu@icloud.com',
        telephone: '0600000000',
        agence: 'VisitPro Admin',
        motDePasse: 'France2000@'
      })
    });
    const data = await res.json();
    if (res.ok) {
      result.className = 'result ok';
      result.innerHTML = '✅ Compte créé ! Tu peux te connecter sur le back-office avec ton email.<br><br><strong>Supprime cette page maintenant.</strong>';
      btn.textContent = 'Compte créé ✓';
    } else if (res.status === 409) {
      result.className = 'result ok';
      result.innerHTML = '✅ Ce compte existe déjà — tu peux te connecter directement.';
      btn.textContent = 'Déjà existant';
    } else {
      throw new Error(data.error || 'Erreur inconnue');
    }
  } catch(e) {
    result.className = 'result err';
    result.innerHTML = '❌ Erreur : ' + e.message;
    btn.disabled = false;
    btn.textContent = 'Réessayer';
  }
  result.style.display = 'block';
}
</script>
</body>
</html>
